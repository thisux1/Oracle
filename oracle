#!/usr/bin/env bash

# ─── Oracle V2 Portable Launcher ───

# Colors for terminal output
RED='\033[0;31m'
GREEN='\033[0;32'
YELLOW='\033[0;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m' # No Color

# Output header
echo -e "${CYAN}${BOLD}Oracle V2 Launcher${NC}"
echo -e "${CYAN}──────────────────────────────────────────────────${NC}"

# Resolve script directory dynamically
PROJECT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
cd "$PROJECT_DIR"

# 1. Check if Python is installed
if ! command -v python3 &> /dev/null; then
    echo -e "${RED}${BOLD}ERROR: Python 3 could not be found!${NC}"
    echo -e "Please install Python 3.11 (recommended) or newer to run Oracle V2."
    exit 1
fi

# 2. Dynamic Virtual Environment Detection
VENV_PATH=""
if [ -d "$PROJECT_DIR/.venv" ]; then
    VENV_PATH="$PROJECT_DIR/.venv"
elif [ -d "$PROJECT_DIR/venv" ]; then
    VENV_PATH="$PROJECT_DIR/venv"
elif [ -d "$PROJECT_DIR/../Epic-Rpg-Macro-main/venv_311" ]; then
    VENV_PATH="$PROJECT_DIR/../Epic-Rpg-Macro-main/venv_311"
fi

if [ -n "$VENV_PATH" ]; then
    echo -e "Found virtual environment: ${GREEN}$VENV_PATH${NC}"
    if [ -f "$VENV_PATH/bin/activate" ]; then
        source "$VENV_PATH/bin/activate"
        echo -e "Activated virtual environment successfully."
    else
        echo -e "${YELLOW}WARNING: Found virtual environment directory but 'bin/activate' script is missing.${NC}"
    fi
else
    echo -e "${YELLOW}No local virtual environment (.venv/venv) detected.${NC}"
    echo -e "Running with current active shell Python. (Assuming dependencies are installed globally or in your current shell environment)"
fi

# 3. Verify core dependencies
echo -e "Verifying application dependencies..."
if ! python3 -c "import textual" &> /dev/null; then
    echo -e "\n${RED}${BOLD}DEPENDENCY ERROR: 'textual' library is not installed in the active environment.${NC}"
    echo -e "${YELLOW}Active Python:${NC} $(which python3)"
    echo -e "\nTo fix this, please run one of the following commands to install dependencies:"
    echo -e "  ${BOLD}pip install -r requirements.txt${NC}"
    echo -e "  or"
    echo -e "  ${BOLD}python3 -m pip install -r requirements.txt${NC}\n"
    exit 1
fi

echo -e "${GREEN}All dependencies verified. Launching Oracle V2...${NC}\n"

# 4. Parse arguments
DASHBOARD_MODE=false
DEV_MODE=false
PASSTHROUGH_ARGS=()

for arg in "$@"; do
    case "$arg" in
        dashboard|--dashboard|-d)
            DASHBOARD_MODE=true
            ;;
        dev|--dev)
            DASHBOARD_MODE=true
            DEV_MODE=true
            ;;
        *)
            PASSTHROUGH_ARGS+=("$arg")
            ;;
    esac
done

# 5. Start the application
if [ "$DASHBOARD_MODE" = true ]; then
    if [ "$DEV_MODE" = true ]; then
        # ── Dev mode: backend + Vite hot-reload in parallel ──────────────────
        echo -e "${CYAN}Starting Oracle in DEV mode (backend + Vite hot-reload)...${NC}"

        # Check node/npm
        if ! command -v npm &> /dev/null; then
            echo -e "${RED}ERROR: npm not found. Install Node.js to use --dev mode.${NC}"
            exit 1
        fi

        # Check dashboard/dist exists for the backend to serve as fallback
        DASHBOARD_DIR="$PROJECT_DIR/dashboard"

        # Start Python backend in background
        echo -e "  ${GREEN}[1/2]${NC} Starting Python backend on ${CYAN}http://127.0.0.1:8000${NC}..."
        python3 -m uvicorn dashboard_server:app \
            --host 127.0.0.1 --port 8000 \
            --reload --log-level warning &
        BACKEND_PID=$!

        # Brief pause so backend is up before Vite tries to proxy
        sleep 1

        # Start Vite dev server in background
        echo -e "  ${GREEN}[2/2]${NC} Starting Vite dev server on ${CYAN}http://127.0.0.1:5173${NC}..."
        (cd "$DASHBOARD_DIR" && npm run dev) &
        VITE_PID=$!

        # Wait for Vite to be ready then open browser
        sleep 2
        echo -e "\n${GREEN}Opening dashboard in browser...${NC}"
        xdg-open "http://127.0.0.1:5173" 2>/dev/null || \
            python3 -c "import webbrowser; webbrowser.open('http://127.0.0.1:5173')"

        echo -e "${CYAN}Dev servers running. Press Ctrl+C to stop both.${NC}"

        # Wait and forward Ctrl+C to both child processes
        trap "kill $BACKEND_PID $VITE_PID 2>/dev/null; exit 0" INT TERM
        wait
    else
        # ── Production mode: serve pre-built dist ─────────────────────────────
        echo -e "${CYAN}Starting Oracle Web Dashboard...${NC}"
        python3 launch_dashboard.py "${PASSTHROUGH_ARGS[@]}"
    fi
else
    # ── TUI mode (default) ───────────────────────────────────────────────────
    python3 main.py "${PASSTHROUGH_ARGS[@]}"
fi
